# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# LOCAL DEV — SQLite (no server needed, file stored at prisma/dev.db)
DATABASE_URL="file:./dev.db"

# PRODUCTION (Proxmox LXC) — SQLite with persistent data directory
# DATABASE_URL="file:/opt/cloglog/data/cloglog.db"

# PRODUCTION (cloud) — swap schema.prisma provider to "postgresql" and use:
# Neon:     postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/cloglog?sslmode=require
# Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Railway:  postgresql://postgres:[password]@[host]:5432/railway

# ─────────────────────────────────────────────
# Auth (NextAuth v5 / Auth.js)
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Or (Node):     node -e "require('crypto').randomBytes(32).toString('base64') |> console.log"
AUTH_SECRET="your-super-secret-key-here"

# ─────────────────────────────────────────────
# OSRS / External APIs
# ─────────────────────────────────────────────
WIKI_USER_AGENT="ClogLog/1.0 (https://github.com/kutweer/osrs-logger; contact@example.com)"

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ClogLog"
NODE_ENV="development"
